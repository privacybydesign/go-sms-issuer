# Copy this file to .env and fill in real values. .env is gitignored.
#
# docker-compose reads these variables. REDIS_PASSWORD is mandatory: the
# compose file fails fast if it is unset, so the Redis instance never starts
# with a hardcoded default password.

# Password for the Redis instance. Use a long, random value in production.
REDIS_PASSWORD=change-me

# Cloudflare Turnstile site key baked into the frontend build.
TURNSTILE_SITE_KEY=
